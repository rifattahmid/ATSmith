# ATSmith LLM credentials
#
# Choose the provider in config.py with LLM_PROVIDER:
#   "anthropic"          -> uses ANTHROPIC_API_KEY
#   "openai"             -> uses OPENAI_API_KEY
#   "openai-compatible"  -> uses LLM_API_KEY + LLM_BASE_URL

# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# OpenAI-compatible endpoint, for providers that expose an OpenAI-style API.
# Configure the exact model in config.py with LLM_MODEL.
# LLM_API_KEY=your_provider_api_key_here
# LLM_BASE_URL=https://provider.example.com/v1

# Optional Azure/OpenAI-compatible usage can be configured by setting:
# LLM_PROVIDER = "openai-compatible"
# LLM_MODEL = "your-deployment-or-model-name"
# LLM_BASE_URL = "https://your-resource.openai.azure.com/openai/v1"
